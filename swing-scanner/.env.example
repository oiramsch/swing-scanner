# ── Alpaca (primary data source) ─────────────────────────────────────────────
# Get your keys at: https://app.alpaca.markets → API Keys
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# Set to true for paper trading account, false for live
ALPACA_PAPER=true
# Paper Trading:  https://paper-api.alpaca.markets
# Live Trading:   https://api.alpaca.markets
# Data (both):    https://data.alpaca.markets  (handled automatically by alpaca-py)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Polygon.io (optional fallback — only used when ALPACA_API_KEY is empty) ───
POLYGON_API_KEY=your_polygon_key_here

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── App ───────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./swing_scanner.db
REDIS_URL=redis://redis:6379
SCAN_TIME_UTC=22:15

# ── Notifications ─────────────────────────────────────────────────────────────
NTFY_TOPIC=your_ntfy_topic_here
RESEND_API_KEY=your_resend_key_here
NOTIFICATION_EMAIL=your@email.com
