# =============================================================================
# Swing Scanner — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# =============================================================================

# ── Data Provider ─────────────────────────────────────────────────────────────
# Which data source to use for the scanner (OHLCV, daily bars)
#
#   yfinance  — FREE, no key needed, S&P 500 universe (DEFAULT — Phase 1)
#   alpaca    — Uses Alpaca IEX feed; limited to ~200-300 symbols on free plan
#
# Phase 1-2: keep yfinance (zero cost)
# Phase 3+:  consider tiingo ($30/mo) or eodhd (€20/mo) when profitable
DATA_PROVIDER=yfinance

# Which stock universe to scan
#   sp500       — ~503 most liquid US stocks, fetched from Wikipedia + cached
#   russell1000 — ~1 000 US large/mid caps
#   custom      — load symbols from CUSTOM_SYMBOLS_FILE
STOCK_UNIVERSE=sp500

# Only needed if STOCK_UNIVERSE=custom
# JSON file with an array of ticker symbols: ["AAPL", "MSFT", ...]
CUSTOM_SYMBOLS_FILE=

# ── Alpaca (broker + portfolio quotes) ───────────────────────────────────────
# Used for:
#   - Live bid/ask quotes for open portfolio positions
#   - Paper/live order execution (Phase 3)
#   - NOT used for scanner data when DATA_PROVIDER=yfinance
#
# Get your keys at: https://app.alpaca.markets → API Keys
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# true  = paper trading account (safe for testing)
# false = live trading account  (real money — use with caution!)
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Polygon.io (legacy — optional) ───────────────────────────────────────────
# Previously used as primary data source. No longer needed with yfinance.
# Can be left empty.
POLYGON_API_KEY=

# ── AI Analysis ──────────────────────────────────────────────────────────────
# Required for chart analysis, deep analysis, and AI portfolio reports.
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── App ───────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./swing_scanner.db
REDIS_URL=redis://redis:6379

# Time (UTC) when the daily scan runs automatically
# 22:15 UTC = 23:15 CET (winter) / 00:15 CEST (summer)
SCAN_TIME_UTC=22:15

# ── Notifications (optional) ─────────────────────────────────────────────────
# ntfy.sh push notifications — create a free topic at https://ntfy.sh
NTFY_TOPIC=your_ntfy_topic_here
RESEND_API_KEY=your_resend_key_here
NOTIFICATION_EMAIL=your@email.com

# ── Screener Defaults ─────────────────────────────────────────────────────────
# These are overridden by the active FilterProfile set in the UI.
# Uncomment and adjust only if you don't use FilterProfiles.
#
# MIN_PRICE=10.0
# MIN_VOLUME=500000
# MIN_RSI=45.0
# MAX_RSI=70.0
# VOLUME_MULTIPLIER=1.5
# MAX_CANDIDATES=50
# LOOKBACK_DAYS=60
