{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI Backend",
      "runtimeExecutable": "swing-scanner/.venv/bin/python",
      "runtimeArgs": [
        "-m", "uvicorn", "backend.main:app",
        "--app-dir", "swing-scanner",
        "--host", "0.0.0.0",
        "--port", "8000"
      ],
      "port": 8000
    },
    {
      "name": "Vite Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "swing-scanner/frontend", "run", "dev"],
      "port": 5173
    }
  ]
}
